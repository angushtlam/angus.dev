---
import "../styles/crt.css";
---

<div class="crt-database-screen crt">
  <div class="color-bars">
    <span class="bar bar-white"></span>
    <span class="bar bar-yellow"></span>
    <span class="bar bar-cyan"></span>
    <span class="bar bar-green"></span>
    <span class="bar bar-magenta"></span>
    <span class="bar bar-red"></span>
    <span class="bar bar-blue"></span>
  </div>
  <div class="lower-bars">
    <span class="lower-blue"></span>
    <span class="lower-black"></span>
    <span class="lower-magenta"></span>
    <span class="lower-black"></span>
    <span class="lower-cyan"></span>
    <span class="lower-black"></span>
    <span class="lower-white"></span>
  </div>
  <div class="bottom-bars">
    <span></span>
    <span></span>
    <span></span>
  </div>
  <div class="database-label">CLICK OR SCROLL DOWN</div>
</div>

<style>
  .crt-database-screen {
    background: #050505;
    height: 100%;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .color-bars,
  .lower-bars {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    left: 0;
    position: absolute;
    width: 100%;
  }

  .color-bars {
    height: 74%;
    top: 0;
  }

  .lower-bars {
    height: 14%;
    top: 74%;
  }

  .bar-white,
  .lower-white {
    background: #d6ecf0;
  }

  .bar-yellow {
    background: #dce913;
  }

  .bar-cyan,
  .lower-cyan {
    background: #12ced1;
  }

  .bar-green {
    background: #16d63c;
  }

  .bar-magenta,
  .lower-magenta {
    background: #c51fd2;
  }

  .bar-red {
    background: #ed2431;
  }

  .bar-blue,
  .lower-blue {
    background: #163bea;
  }

  .lower-black {
    background: #080808;
  }

  .bottom-bars {
    bottom: 0;
    display: grid;
    grid-template-columns: 1fr 1.8fr 2.8fr;
    height: 12%;
    left: 0;
    position: absolute;
    width: 52%;
  }

  .bottom-bars span:nth-child(1) {
    background: #0d34d8;
  }

  .bottom-bars span:nth-child(2) {
    background: #dbe9e9;
  }

  .bottom-bars span:nth-child(3) {
    background: #1437d1;
  }

  .database-label {
    background: #263044;
    box-shadow: 0 0 10px rgb(0 0 0 / 65%);
    color: #fff;
    font-family: "Courier New", monospace;
    font-size: clamp(1.25rem, 6vw, 4rem);
    font-weight: 700;
    left: 50%;
    letter-spacing: 0.04em;
    padding: 0.14em 0.32em;
    position: absolute;
    text-shadow: 2px 0 #8ed8e8;
    top: 52%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    z-index: 1;
  }
</style>
