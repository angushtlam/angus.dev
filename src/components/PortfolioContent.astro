---
import Footer from "./Footer.astro";

interface Props {
  darkMode?: boolean;
  exposeSectionIds?: boolean;
}

const { darkMode = false, exposeSectionIds = true } = Astro.props;
---

<div class:list={["page-wrapper", { "dark-mode": darkMode }]}>
  <main class="page-content">
    <aside class="sidebar">
      <a class="wordmark" href="/">
        <span>Angus Lam</span>
        <span>Software Development</span>
      </a>
      <nav class="sidebar-nav" aria-label="Primary">
        <a href="#specialties">Areas of specialties</a>
        <a href="#experience">Work experience</a>
        <a href="#education">Education</a>
        <a href="#technical-skills">Technical skills</a>
        <a href="#projects">Side projects</a>
        <a href="#contact">Contact me</a>
      </nav>
      <div class="sidebar-footer">
        <div class="sidebar-links">
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://linkedin.com/in/angushtlam">LinkedIn ↗</a
          >
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://anguslam.com">Personal site ↗</a
          >
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://angushtlam.substack.com">Substack ↗</a
          >
        </div>
      </div>
    </aside>

    <div class="content-column">
      <div class="mobile-wordmark">
        <a href="/">Angus Lam Software Development</a>
      </div>
      <header class="intro">
        <p class="eyebrow">Senior software engineer // New York</p>
        <h1>
          I build secure and compliant users-first software products for
          globally ambitious companies.
        </h1>
        <div class="intro-footer">
          <p>
            Over a decade of building scalable, user-facing full-stack
            applications across cybersecurity, privacy, data protection, and
            product domains.
          </p>
          <p>
            Currently at <a
              target="_blank"
              rel="noopener noreferrer"
              href="https://stripe.com">Stripe ↗</a
            >, working on security and privacy for merchants and consumers.
          </p>
        </div>
      </header>

      <nav class="mobile-index" aria-label="Page sections">
        <a href="#specialties">Areas of specialties</a>
        <a href="#experience">Work experience</a>
        <a href="#education">Education</a>
        <a href="#technical-skills">Technical skills</a>
        <a href="#projects">Side projects</a>
        <a href="#contact">Contact me</a>
      </nav>

      <section
        class="section specialties"
        id={exposeSectionIds ? "specialties" : undefined}
      >
        <div class="section-heading">
          <p class="eyebrow">Areas of specialty</p>
          <h2>Full stack engineering meets product judgment.</h2>
        </div>

        <article class="feature">
          <div>
            <h3>Cybersecurity</h3>
            <div class="feature-grid">
              <div>
                <h4>Software dependency supply chain risk monitoring</h4>
                <p>
                  Built and productionized AI agents that monitor third-party
                  integrations across Stripe's codebase through continuous
                  integration. Created data pipelines that give security
                  leadership queryable insight into risk exposure.
                </p>
              </div>
              <div>
                <h4>Authentication at global scale</h4>
                <p>
                  Reduced cross-region dashboard latency by 500ms for millions
                  of daily requests. Wrote the first service-oriented API key
                  authentication implementation for Stripe's multi-language
                  stack.
                </p>
              </div>
            </div>
          </div>
        </article>

        <article class="feature">
          <div>
            <h3>Privacy & data protection</h3>
            <div class="feature-grid">
              <div>
                <h4>
                  <a
                    target="_blank"
                    rel="noopener noreferrer"
                    href="https://docs.stripe.com/privacy/redaction"
                    >Redaction API ↗</a
                  >
                </h4>
                <p>
                  A programmable tool for businesses managing retention
                  requirements across KYC, tax, and consumer privacy regulations
                  in multiple jurisdictions.
                </p>
              </div>
              <div>
                <h4>
                  <a
                    target="_blank"
                    rel="noopener noreferrer"
                    href="https://privacy.stripe.com/">Privacy Portal ↗</a
                  >
                </h4>
                <p>
                  Automated self-serve tools for consumers to access or delete
                  their data across Stripe's decentralized, multi-product user
                  model.
                </p>
              </div>
              <div>
                <h4>Privacy-first growth</h4>
                <p>
                  Implemented consent systems for web and asynchronous
                  first-party data, enabling a multimillion-dollar paid media
                  funnel while respecting visitor choices.
                </p>
              </div>
            </div>
          </div>
        </article>

        <article class="feature">
          <div>
            <h3>Cross-functional collaboration</h3>
            <div class="feature-grid">
              <div>
                <h4>Regulation into systems</h4>
                <p>
                  Partner with business leads and lawyers to translate GDPR,
                  CCPA, ePrivacy, data locality, and localization requirements
                  into technical systems that unblock growth and market access.
                </p>
              </div>
              <div>
                <h4>UI/UX direction</h4>
                <p>
                  Shape visual products with designers and create Figma
                  dashboard and workflow prototypes when projects are unstaffed,
                  accelerating frontend delivery by months.
                </p>
              </div>
            </div>
          </div>
        </article>
      </section>

      <section
        class="section history"
        id={exposeSectionIds ? "experience" : undefined}
      >
        <div class="section-heading">
          <p class="eyebrow">Work history</p>
          <h2>Enterprises, startups, and one man shows.</h2>
        </div>

        <div class="timeline">
          <article>
            <p class="date">2019—2026</p>
            <h3>
              <a
                target="_blank"
                rel="noopener noreferrer"
                href="https://stripe.com">Stripe ↗</a
              >
            </h3>
            <p>Software Engineer</p>
            <p class="meta">San Francisco · New York · Remote</p>
          </article>
          <article>
            <p class="date">2019</p>
            <h3>
              <a
                target="_blank"
                rel="noopener noreferrer"
                href="https://lugg.com">Lugg ↗</a
              >
            </h3>
            <p>Software Engineer</p>
            <p class="meta">New York · Remote</p>
          </article>
          <article>
            <p class="date">2018</p>
            <h3>
              <a
                target="_blank"
                rel="noopener noreferrer"
                href="https://stripe.com">Stripe ↗</a
              >
            </h3>
            <p>Software Engineer Intern</p>
            <p class="meta">San Francisco</p>
          </article>
          <article>
            <p class="date">2017</p>
            <h3>
              <a
                target="_blank"
                rel="noopener noreferrer"
                href="https://optimizely.com">Optimizely ↗</a
              >
            </h3>
            <p>Software Engineer Intern</p>
            <p class="meta">San Francisco</p>
          </article>
          <article>
            <p class="date">2017—2018</p>
            <h3>
              <a
                target="_blank"
                rel="noopener noreferrer"
                href="https://pitchpivot.com">Pitch + Pivot ↗</a
              >
            </h3>
            <p>Software Engineer</p>
            <p class="meta">Buffalo · Remote</p>
          </article>
          <article>
            <p class="date">2012—2016</p>
            <h3>Independent</h3>
            <p>Game Developer</p>
            <p class="meta">New York · Remote</p>
          </article>
        </div>
      </section>

      <section
        class="section education"
        id={exposeSectionIds ? "education" : undefined}
      >
        <div class="section-heading">
          <p class="eyebrow">Education</p>
          <h2>
            Two degrees. Computer science and linguistics with a computational
            focus.
          </h2>
        </div>
        <div class="education-grid">
          <p class="school">University at Buffalo, 2019</p>
          <div>
            <p>
              <strong>Computer Science B.S.</strong><br />
              GPA 3.637 · magna cum laude
            </p>
            <p>
              <strong>Linguistics B.A.</strong><br />
              Language, Society & Communication · GPA 3.89 · summa cum laude
            </p>
          </div>
        </div>
      </section>

      <section
        class="section skills"
        id={exposeSectionIds ? "technical-skills" : undefined}
      >
        <div class="section-heading">
          <p class="eyebrow">Technical skills</p>
          <h2>Full-stack engineering from interface to infrastructure.</h2>
        </div>
        <div class="skills-grid">
          <article>
            <h3>Software</h3>
            <p>Python, Java, Ruby, JavaScript, HTML, CSS, React</p>
          </article>
          <article>
            <h3>Infrastructure</h3>
            <p>AWS, Lambda, S3, EC2, SQL, Spark, Kafka, RabbitMQ</p>
          </article>
          <article>
            <h3>Artificial intelligence</h3>
            <p>
              Production LLM systems, auditable agents, MCP, skills, and harness
              engineering
            </p>
          </article>
          <article>
            <h3>Product leadership</h3>
            <p>
              Project direction, user research, staffing, measurement, and
              data-driven prioritization
            </p>
          </article>
        </div>
      </section>

      <section
        class="section projects"
        id={exposeSectionIds ? "projects" : undefined}
      >
        <div class="section-heading">
          <p class="eyebrow">Side projects</p>
          <h2>Collection of select self-published software.</h2>
        </div>
        <div class="project-list">
          <article>
            <h3>
              <a
                href="https://moodboring.com"
                target="_blank"
                rel="noopener noreferrer">Moodboring</a
              >
            </h3>
            <p>
              An online photo editor for making eclectic social mood boards.
            </p>
          </article>
          <article>
            <h3>Cookiedip <span class="tag-coming-soon">Coming soon</span></h3>
            <p>
              Open source cookie identification inspired by tools used by
              privacy regulators.
            </p>
          </article>
        </div>
      </section>

      <section class="contact" id={exposeSectionIds ? "contact" : undefined}>
        <p class="eyebrow">Let's make something groundbreaking</p>
        <h2>
          Reach out to collaborate on ambitious software and creative technology
          projects.
        </h2>
        <div class="contact-links">
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://linkedin.com/in/angushtlam">LinkedIn ↗</a
          >
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://angushtlam.substack.com">Substack ↗</a
          >
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://anguslam.com">Personal site ↗</a
          >
        </div>
        <Footer />
      </section>
    </div>
  </main>
</div>

<style>
  .page-wrapper {
    --ink: #111111;
    --paper: #f1f0eb;
    --accent: #3347ff;
    --muted: #686868;
    background: var(--paper);
    color: var(--ink);
    min-height: 100vh;
    width: 100%;
  }

  .page-wrapper.dark-mode {
    --ink: #ff6a00;
    --paper: #050505;
    --accent: #ff9a3c;
    --muted: #c16f36;
  }

  .page-content {
    display: grid;
    grid-template-columns: clamp(240px, 20vw, 340px) minmax(0, 1fr);
    margin: 0 auto;
    max-width: 1800px;
    min-height: 100%;
  }

  .sidebar {
    align-self: start;
    border-right: 1px solid var(--ink);
    display: flex;
    flex-direction: column;
    height: 100vh;
    justify-content: space-between;
    padding: 32px;
    position: sticky;
    top: 0;
  }

  .wordmark {
    color: inherit;
    display: flex;
    flex-direction: column;
    font-size: clamp(1.75rem, 2.5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    text-decoration: none;
  }

  .sidebar-nav {
    border-top: 1px solid var(--ink);
  }

  .sidebar-nav a {
    align-items: center;
    border-bottom: 1px solid var(--ink);
    display: grid;
    font-size: 0.9rem;
    padding: 12px 0;
    font-weight: 600;
    text-transform: uppercase;
  }

  .sidebar-footer {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sidebar-footer p {
    margin-bottom: 4px;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 24px;
  }

  .sidebar-links a {
    font-weight: 700;
  }

  .content-column {
    min-width: 0;
  }

  .intro,
  .section,
  .contact {
    padding: clamp(24px, 4vw, 64px);
  }

  .intro {
    min-height: 90vh;
  }

  .eyebrow,
  .date,
  .meta {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .intro > .eyebrow {
    margin-top: clamp(56px, 10vh, 140px);
  }

  h1,
  h2,
  h3,
  h4,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(3.33rem, 7vw, 6rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 0.95;
    margin: 24px 0 clamp(60px, 12vh, 160px);
    max-width: 1400px;
  }

  .intro-footer {
    display: grid;
    font-size: clamp(1.15rem, 2vw, 1.8rem);
    gap: 40px;
    grid-template-columns: 1fr 1fr;
    line-height: 1.25;
    max-width: 900px;
  }

  a {
    color: var(--accent);
    text-decoration: underline;
  }

  .section {
    border-top: 1px solid var(--ink);
  }

  .section-heading {
    display: grid;
    gap: 40px;
    grid-template-columns: minmax(180px, 1fr) 3fr;
    margin-bottom: clamp(80px, 14vw, 200px);
  }

  .section-heading h2,
  .contact h2 {
    font-size: clamp(2.8rem, 5.5vw, 6.5rem);
    font-weight: 500;
    letter-spacing: -0.055em;
    line-height: 0.92;
    margin: 0;
  }

  .feature {
    border-top: 1px solid var(--ink);
    padding: 32px 0 clamp(80px, 12vw, 160px);
  }

  .feature h3 {
    font-size: clamp(2.5rem, 5vw, 5.5rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    margin-bottom: 60px;
  }

  .feature-grid {
    display: grid;
    gap: 48px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-grid h4,
  .skills-grid h3,
  .project-list h3 {
    font-size: 1rem;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .tag-coming-soon {
    border: 1px solid currentColor;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    vertical-align: middle;
  }

  .feature-grid p,
  .skills-grid p,
  .project-list p,
  .education-grid {
    font-size: clamp(1.1rem, 1.5vw, 1.45rem);
    line-height: 1.45;
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline article {
    align-items: baseline;
    border-top: 1px solid var(--ink);
    display: flex;
    gap: 24px;
    padding: 20px 0;
  }

  .timeline .date {
    flex-shrink: 0;
    width: 22ch;
  }

  .timeline h3 {
    flex-shrink: 0;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .timeline article > p:not(.date, .meta) {
    font-size: 1.2rem;
  }

  .skills-grid article {
    border-top: 1px solid var(--ink);
    padding: 16px 0;
  }

  .project-list article {
    border-top: 1px solid var(--ink);
    padding: 16px 0;
  }

  .meta {
    color: var(--muted);
    margin-left: auto;
  }

  .education-grid {
    border-top: 1px solid var(--ink);
    display: grid;
    gap: 40px;
    grid-template-columns: 1fr 2fr;
    padding-top: 32px;
  }

  .school {
    font-weight: 700;
  }

  .education-grid div {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr 1fr;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .project-list {
    display: grid;
    grid-template-columns: 1fr;
  }

  .contact {
    background: var(--ink);
    color: var(--paper);
    min-height: 100vh;
    padding-top: clamp(80px, 12vw, 180px);
  }

  .contact h2 {
    max-width: 1250px;
  }

  .contact-links {
    background: white;
    display: flex;
    flex-wrap: wrap;
    font-size: clamp(1.4rem, 3vw, 3rem);
    gap: 18px 48px;
    margin-top: clamp(80px, 14vw, 200px);
    padding: clamp(20px, 3vw, 40px);
  }

  .mobile-index,
  .mobile-wordmark {
    display: none;
  }

  @media screen and (max-width: 1100px) {
    .page-content {
      grid-template-columns: 1fr;
    }

    .sidebar {
      display: none;
    }

    .mobile-wordmark {
      border-bottom: 1px solid var(--ink);
      display: block;
      padding: 16px 24px;
    }

    .mobile-wordmark a {
      color: inherit;
      font-size: clamp(1.5rem, 5vw, 2rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1;
      text-decoration: none;
    }

    .mobile-index {
      border-top: 1px solid var(--ink);
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding: 0 24px;
    }

    .mobile-index a {
      border-bottom: 1px solid var(--ink);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      padding: 12px 0;
      text-transform: uppercase;
    }

    .mobile-index a:hover {
      color: var(--accent);
    }

    .intro-footer,
    .section-heading,
    .feature,
    .education-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      gap: 20px;
    }

    .timeline article {
      display: grid;
      grid-template-columns: 11ch 1fr;
      padding: 12px 0;
    }

    .timeline .date {
      grid-column: 1;
      grid-row: 1 / 4;
    }

    .timeline h3 {
      grid-column: 2;
      grid-row: 1;
    }

    .timeline article > p:not(.date, .meta) {
      grid-column: 2;
      grid-row: 2;
      margin-bottom: 0;
      text-align: left;
    }

    .timeline .meta {
      grid-column: 2;
      grid-row: 3;
      margin-left: 0;
      text-align: left;
    }
  }

  @media screen and (max-width: 600px) {
    .mobile-wordmark {
      padding: 16px 20px;
    }

    .mobile-index {
      grid-template-columns: 1fr 1fr;
      padding: 0 20px;
    }

    .intro,
    .section,
    .contact {
      padding: 40px 20px;
    }

    h1 {
      font-size: clamp(2.5rem, 12vw, 4.5rem);
    }

    .intro-footer,
    .feature-grid,
    .education-grid div {
      grid-template-columns: 1fr;
    }
  }
</style>
