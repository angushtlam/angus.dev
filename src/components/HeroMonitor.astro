---
import CrtDatabaseScreen from "./CrtDatabaseScreen.astro";
import monitorUrl from "../assets/monitor.glb?url";
import screenUrl from "../assets/screen.glb?url";
import "../styles/crt.css";

interface Props {
  ariaLabel?: string;
}

const { ariaLabel = "Show content" } = Astro.props;
---

<div class="hero-scroll-region" id="hero-scroll-region">
  <div class="hero-intro-content" id="hero-intro-content">
    <CrtDatabaseScreen />
  </div>
  <div class="hero-monitor" id="hero-monitor">
    <canvas
      id="hero-canvas"
      data-model-url={monitorUrl}
      data-screen-model-url={screenUrl}
      role="button"
      tabindex="0"
      aria-label={ariaLabel}></canvas>
  </div>
  <div class="hero-screen-reveal" id="hero-screen-reveal">
    <div class="hero-screen-content crt" id="hero-screen-content">
      <slot />
    </div>
  </div>
</div>
<button
  class="hero-animation-toggle"
  id="hero-animation-toggle"
  type="button"
  aria-pressed="false"
>
  Reduce animation
</button>

<script>
  import html2canvas from "html2canvas";
  import * as THREE from "three";
  import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";

  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
  const container = document.getElementById("hero-monitor") as HTMLDivElement;
  const screenContent = document.getElementById(
    "hero-screen-content"
  ) as HTMLDivElement;
  const introContent = document.getElementById(
    "hero-intro-content"
  ) as HTMLDivElement;
  const screenReveal = document.getElementById(
    "hero-screen-reveal"
  ) as HTMLDivElement;
  const scrollRegion = document.getElementById("hero-scroll-region")!;
  const animationToggle = document.getElementById(
    "hero-animation-toggle"
  ) as HTMLButtonElement;
  const animationDisabled =
    localStorage.getItem("disableHeroMonitorAnimation") === "true";
  const monitorMediaQuery = window.matchMedia(
    "(min-aspect-ratio: 24 / 20) and (min-height: 600px)"
  );
  const shouldRenderMonitor = monitorMediaQuery.matches && !animationDisabled;

  animationToggle.ariaPressed = String(animationDisabled);
  animationToggle.textContent = animationDisabled
    ? "Enable animation"
    : "Reduce animation";
  animationToggle.addEventListener("click", () => {
    localStorage.setItem(
      "disableHeroMonitorAnimation",
      String(!animationDisabled)
    );
    window.location.reload();
  });

  // Reload only when crossing the layout boundary so WebGL is fully created or torn down.
  monitorMediaQuery.addEventListener("change", () => {
    window.location.reload();
  });

  if (!shouldRenderMonitor) {
    scrollRegion.classList.add("show-content-directly");
    screenContent.classList.remove("crt");
    canvas.setAttribute("aria-hidden", "true");
    canvas.tabIndex = -1;
  } else {
    const modelUrl = canvas.dataset.modelUrl!;
    const screenModelUrl = canvas.dataset.screenModelUrl!;

    const START_Z = 2.1;
    const END_Z = 1.75;

    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(
      100,
      container.clientWidth / container.clientHeight,
      0.01,
      100
    );
    camera.position.set(0, 0, START_Z);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.7;

    // A large unlit plane provides the animated backdrop behind the monitor.
    const backgroundMaterial = new THREE.ShaderMaterial({
      depthWrite: false,
      uniforms: {
        time: { value: 0 },
      },
      vertexShader: `
      varying vec2 vUv;

      void main() {
        vUv = uv;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
      fragmentShader: `
      uniform float time;
      varying vec2 vUv;

      void main() {
        float waveOne = sin(vUv.x * 8.0 + time * 0.7) * 0.06;
        float waveTwo = sin(vUv.x * 13.0 - time * 0.45) * 0.035;
        float wave = smoothstep(
          0.38 + waveOne + waveTwo,
          0.72 + waveOne + waveTwo,
          vUv.y
        );

        vec3 deepPurple = vec3(0.025, 0.025, 0.09);
        vec3 brightPurple = vec3(0.2, 0.18, 0.32);
        vec3 color = mix(deepPurple, brightPurple, wave);

        gl_FragColor = vec4(color, 1.0);
      }
    `,
    });
    const background = new THREE.Mesh(
      new THREE.PlaneGeometry(20, 20),
      backgroundMaterial
    );
    background.position.z = -2;
    background.renderOrder = -1;
    scene.add(background);

    scene.add(new THREE.AmbientLight(0x101830, 0.2));

    const keyLight = new THREE.DirectionalLight(0xccffff, 0.8);
    keyLight.position.set(4, 3, 3);
    scene.add(keyLight);

    const rimLight = new THREE.DirectionalLight(0xff6600, 1);
    rimLight.position.set(-3, 1, -4);
    scene.add(rimLight);

    // These two lights mirror each other as the pointer moves across the hero.
    const cursorLight = new THREE.DirectionalLight(0x3320ee, 0.7);
    const cursorLightPosition = new THREE.Vector3(0, 0, 4);
    cursorLight.position.copy(cursorLightPosition);
    scene.add(cursorLight);
    scene.add(cursorLight.target);

    const oppositeCursorLight = new THREE.DirectionalLight(0xff2020, 0.15);
    const oppositeCursorLightPosition = new THREE.Vector3(0, 0, 4);
    oppositeCursorLight.position.copy(oppositeCursorLightPosition);
    scene.add(oppositeCursorLight);
    scene.add(oppositeCursorLight.target);

    let pivot: THREE.Group | null = null;
    let screenMaterial: THREE.MeshBasicMaterial | null = null;
    let introTexture: THREE.CanvasTexture | null = null;
    let screenTexture: THREE.CanvasTexture | null = null;
    let textureRefreshTimeout: ReturnType<typeof setTimeout>;
    let textureRefreshRequest = 0;
    let spinStart: number | null = null;
    const finalRotationY = -Math.PI / 2;
    const entranceRotation = Math.PI / 6;
    const startPos = new THREE.Vector3(0, 0, START_Z);
    const screenCenter = new THREE.Vector3(0, 0, 0);
    const endPos = new THREE.Vector3(0, 0, END_Z);

    // Render DOM content into canvases that can be used as Three.js textures.
    async function captureContent(element: HTMLElement) {
      await document.fonts.ready;
      return html2canvas(element, {
        backgroundColor: null,
        logging: false,
        scale: 1,
      });
    }

    function refreshScreenTextures() {
      if (!screenTexture) return;

      // Debounce expensive html2canvas captures and discard stale async results.
      const request = ++textureRefreshRequest;
      clearTimeout(textureRefreshTimeout);
      textureRefreshTimeout = setTimeout(async () => {
        const [introCanvas, screenCanvas] = await Promise.all([
          captureContent(introContent),
          captureContent(screenContent),
        ]);
        if (request !== textureRefreshRequest || !screenTexture) return;

        if (introTexture) {
          introTexture.image = introCanvas;
          introTexture.needsUpdate = true;
        }
        screenTexture.image = screenCanvas;
        screenTexture.needsUpdate = true;
        renderer.render(scene, camera);
      }, 500);
    }

    function redrawCanvas() {
      const width = container.clientWidth;
      const height = container.clientHeight;

      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(width, height);
      updateCameraFromScroll();
      renderer.render(scene, camera);
      refreshScreenTextures();
    }

    const loader = new GLTFLoader();
    Promise.all([
      loader.loadAsync(modelUrl),
      loader.loadAsync(screenModelUrl),
    ]).then(async ([gltf, screenGltf]) => {
      const loaded = gltf.scene;

      // Scale to a predictable unit size
      const box = new THREE.Box3().setFromObject(loaded);
      const size = box.getSize(new THREE.Vector3());
      const maxDim = Math.max(size.x, size.y, size.z);
      const modelScale = 2.5 / maxDim;
      loaded.scale.setScalar(modelScale);

      // Recompute after scale, offset geometry so its center sits at the pivot's origin
      box.setFromObject(loaded);
      const center = box.getCenter(new THREE.Vector3());
      loaded.position.sub(center);

      const screenModel = screenGltf.scene;
      screenModel.scale.setScalar(modelScale);
      screenModel.position.sub(center);

      // Pivot group: rotation is now about the geometry center
      pivot = new THREE.Group();
      pivot.add(loaded);
      pivot.rotation.y = finalRotationY - entranceRotation;
      pivot.position.y = -0.225;
      scene.add(pivot);
      spinStart = performance.now();

      const [introCanvas, screenCanvas] = await Promise.all([
        captureContent(introContent),
        captureContent(screenContent),
      ]);

      introTexture = new THREE.CanvasTexture(introCanvas);
      introTexture.colorSpace = THREE.SRGBColorSpace;
      introTexture.flipY = false;
      screenTexture = new THREE.CanvasTexture(screenCanvas);
      screenTexture.colorSpace = THREE.SRGBColorSpace;
      screenTexture.flipY = false;

      // Keep the screen fully bright and independent from scene lights and tone mapping.
      screenMaterial = new THREE.MeshBasicMaterial({
        color: 0xffffff,
        map: introTexture,
        polygonOffset: true,
        polygonOffsetFactor: -1,
        polygonOffsetUnits: -4,
        toneMapped: false,
      });

      screenModel.traverse((object) => {
        if (object instanceof THREE.Mesh) {
          object.material = screenMaterial;
        }
      });
      pivot.add(screenModel);

      pivot.updateMatrixWorld(true);
      // Briefly show the test pattern before replacing it with the page texture.
      setTimeout(() => {
        if (!screenMaterial || !screenTexture) return;

        screenMaterial.map = screenTexture;
        screenMaterial.needsUpdate = true;
      }, 500);

      camera.lookAt(screenCenter);
      updateCameraFromScroll();
    });

    let hasReachedBottom = false;
    let snapTarget: 0 | 1 | null = null;
    const REVEAL_THRESHOLD = 0.15;

    const scrollContainer = (container.closest<HTMLElement>(".root-wrapper") ??
      container.closest<HTMLElement>(".screen"))!;
    let previousScrollTop = scrollContainer.scrollTop;
    let isScrollingUp = false;

    function getScrollProgress() {
      const scrollable = Math.max(
        scrollRegion.clientHeight - container.clientHeight,
        1
      );
      return THREE.MathUtils.clamp(
        (scrollContainer.scrollTop - scrollRegion.offsetTop) / scrollable,
        0,
        1
      );
    }

    function updateCameraFromScroll() {
      const progress = getScrollProgress();

      // Move directly toward the modeled screen as the transition region scrolls.
      camera.position.lerpVectors(startPos, endPos, progress);
      camera.lookAt(screenCenter);
      hasReachedBottom = progress >= 0.999;
      screenReveal.classList.toggle("is-visible", hasReachedBottom);
      screenContent.classList.toggle("crt", !hasReachedBottom);
      canvas.classList.toggle("is-clickable", !hasReachedBottom);
      canvas.setAttribute("aria-disabled", String(hasReachedBottom));
      canvas.tabIndex = hasReachedBottom ? -1 : 0;
    }

    function scrollToProgress(progress: 0 | 1) {
      snapTarget = progress;
      scrollContainer.scrollTo({
        behavior: "smooth",
        top:
          scrollRegion.offsetTop +
          progress * (scrollRegion.clientHeight - container.clientHeight),
      });
    }

    function showReveal() {
      if (!hasReachedBottom) scrollToProgress(1);
    }

    canvas.addEventListener("click", showReveal);
    canvas.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        showReveal();
      }
    });
    container.addEventListener("pointermove", (event) => {
      const bounds = container.getBoundingClientRect();
      const x = ((event.clientX - bounds.left) / bounds.width) * 2 - 1;
      const y = -(((event.clientY - bounds.top) / bounds.height) * 2 - 1);

      cursorLightPosition.set(x * 5, y * 3.5, 4);
      oppositeCursorLightPosition.set(-x * 5, -y * 3.5, 4);
    });
    container.addEventListener("pointerleave", () => {
      cursorLightPosition.set(0, 0, 4);
      oppositeCursorLightPosition.set(0, 0, 4);
    });

    scrollContainer.addEventListener("scroll", () => {
      isScrollingUp = scrollContainer.scrollTop < previousScrollTop;
      previousScrollTop = scrollContainer.scrollTop;
      updateCameraFromScroll();

      const progress = getScrollProgress();
      if (snapTarget !== null) {
        if (
          (snapTarget === 0 && progress <= 0.001) ||
          (snapTarget === 1 && progress >= 0.999)
        ) {
          snapTarget = null;
        }
        return;
      }

      // Downward scrolling reveals after 15%; upward scrolling returns to the monitor.
      if (isScrollingUp && progress > 0 && progress < 1) {
        scrollToProgress(0);
      } else if (
        !isScrollingUp &&
        progress >= REVEAL_THRESHOLD &&
        progress < 1
      ) {
        scrollToProgress(1);
      }
    });

    const observer = new ResizeObserver(redrawCanvas);
    observer.observe(container);
    window.addEventListener("resize", redrawCanvas);

    const animationStart = performance.now();

    function animate() {
      requestAnimationFrame(animate);
      backgroundMaterial.uniforms.time.value =
        (performance.now() - animationStart) / 1000;
      cursorLight.position.lerp(cursorLightPosition, 0.08);
      oppositeCursorLight.position.lerp(oppositeCursorLightPosition, 0.08);
      if (pivot && spinStart !== null) {
        // Ease the model through its short entrance rotation, ending at its resting angle.
        const progress = Math.min((performance.now() - spinStart) / 700, 1);
        const easedProgress = 1 - Math.pow(1 - progress, 3);
        pivot.rotation.y =
          finalRotationY - entranceRotation * (1 - easedProgress);

        if (progress === 1) spinStart = null;
      }
      renderer.render(scene, camera);
    }
    animate();
  }
</script>

<style>
  /* Tall region that creates scroll room; canvas stays sticky inside */
  .hero-scroll-region {
    height: 150vh;
    position: relative;
  }

  .hero-intro-content {
    height: 100vh;
    left: -200vw;
    position: fixed;
    top: 0;
    width: 100vw;
  }

  .hero-monitor {
    height: 100vh;
    position: sticky;
    top: 0;
    width: 100%;
    z-index: 1;
  }

  .hero-screen-reveal {
    align-items: center;
    bottom: 0;
    display: flex;
    height: 100vh;
    justify-content: center;
    left: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transition: opacity 600ms ease;
    width: 100%;
    z-index: 2;
  }

  .hero-screen-reveal.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .hero-screen-content {
    height: 100%;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  #hero-canvas {
    display: block;
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  #hero-canvas.is-clickable {
    cursor: pointer;
  }

  .hero-animation-toggle {
    background: #131313;
    border: 1px solid #c3cacc;
    bottom: 12px;
    color: #c3cacc;
    cursor: pointer;
    display: none;
    font: inherit;
    left: 12px;
    padding: 8px 10px;
    position: fixed;
    z-index: 10;
  }

  .hero-animation-toggle:focus-visible {
    outline: 2px solid #61b2ff;
    outline-offset: 2px;
  }

  @media screen and (min-aspect-ratio: 24 / 20) and (min-height: 600px) {
    .hero-animation-toggle {
      display: block;
    }
  }

  .hero-scroll-region.show-content-directly {
    height: auto;
  }

  .hero-scroll-region.show-content-directly .hero-intro-content,
  .hero-scroll-region.show-content-directly .hero-monitor {
    display: none;
  }

  .hero-scroll-region.show-content-directly .hero-screen-reveal {
    display: block;
    height: auto;
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .hero-scroll-region.show-content-directly .hero-screen-content {
    height: auto;
    min-height: 100vh;
    overflow: visible;
  }

  .hero-scroll-region.show-content-directly .hero-screen-content.crt::before,
  .hero-scroll-region.show-content-directly .hero-screen-content.crt::after {
    display: none;
  }

  @media screen and (aspect-ratio < 24 / 20), screen and (height < 600px) {
    .hero-scroll-region:not(.show-content-directly) {
      height: auto;
    }

    .hero-scroll-region:not(.show-content-directly) .hero-intro-content,
    .hero-scroll-region:not(.show-content-directly) .hero-monitor {
      display: none;
    }

    .hero-scroll-region:not(.show-content-directly) .hero-screen-reveal {
      display: block;
      height: auto;
      opacity: 1;
      pointer-events: auto;
      position: relative;
    }

    .hero-scroll-region:not(.show-content-directly) .hero-screen-content {
      height: auto;
      min-height: 100vh;
      overflow: visible;
    }

    .hero-scroll-region:not(.show-content-directly)
      .hero-screen-content.crt::before,
    .hero-scroll-region:not(.show-content-directly)
      .hero-screen-content.crt::after {
      display: none;
    }
  }
</style>
