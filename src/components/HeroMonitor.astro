---
import crtMonitorUrl from "../assets/crt_monitor.glb?url";
---

<div class="hero-scroll-region" id="hero-scroll-region">
  <div class="hero-monitor" id="hero-monitor">
    <canvas id="hero-canvas" data-model-url={crtMonitorUrl}></canvas>
  </div>
</div>

<script>
  import * as THREE from "three";
  import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";

  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement;
  const container = document.getElementById("hero-monitor") as HTMLDivElement;
  const modelUrl = canvas.dataset.modelUrl!;

  const START_Z = 3.0;
  const END_Z = 1.5;

  const scene = new THREE.Scene();

  const camera = new THREE.PerspectiveCamera(
    100,
    container.clientWidth / container.clientHeight,
    0.1,
    1000
  );
  camera.position.set(0, 0, START_Z);

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,
  });
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
  scene.add(ambientLight);

  const keyLight = new THREE.DirectionalLight(0xffffff, 1.2);
  keyLight.position.set(2, 3, 4);
  scene.add(keyLight);

  const fillLight = new THREE.DirectionalLight(0x8899ff, 0.4);
  fillLight.position.set(-1, -1, -2);
  scene.add(fillLight);

  let pivot: THREE.Group | null = null;
  const startPos = new THREE.Vector3(0, 0, START_Z);
  const screenCenter = new THREE.Vector3(0, 0, 0);
  let endPos = new THREE.Vector3(0, 0, END_Z);

  const loader = new GLTFLoader();
  loader.load(modelUrl, (gltf) => {
    const loaded = gltf.scene;

    // Scale to a predictable unit size
    const box = new THREE.Box3().setFromObject(loaded);
    const size = box.getSize(new THREE.Vector3());
    const maxDim = Math.max(size.x, size.y, size.z);
    loaded.scale.setScalar(2.5 / maxDim);

    // Recompute after scale, offset geometry so its center sits at the pivot's origin
    box.setFromObject(loaded);
    const center = box.getCenter(new THREE.Vector3());
    loaded.position.sub(center);

    // Pivot group: rotation is now about the geometry center
    pivot = new THREE.Group();
    pivot.add(loaded);
    pivot.rotation.y = -Math.PI / 2;
    pivot.position.y = -0.25;
    scene.add(pivot);

    // End position: 1 unit back from screen along the start→screen direction
    const approach = screenCenter.clone().sub(startPos).normalize();
    endPos = screenCenter.clone().sub(approach.multiplyScalar(1.0));

    camera.lookAt(screenCenter);
  });

  let isScrolling = false;
  let scrollTimeout: ReturnType<typeof setTimeout>;

  const scrollRegion = document.getElementById("hero-scroll-region")!;
  const scrollContainer = (container.closest<HTMLElement>(".root-wrapper") ??
    container.closest<HTMLElement>(".screen"))!;

  scrollContainer.addEventListener("scroll", () => {
    const scrollable = scrollRegion.clientHeight - container.clientHeight;
    const progress = Math.min(scrollContainer.scrollTop / scrollable, 1);

    camera.position.lerpVectors(startPos, endPos, progress);
    camera.position.z = Math.max(camera.position.z, END_Z);
    camera.lookAt(screenCenter);

    isScrolling = true;
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      isScrolling = false;
    }, 150);
  });

  const observer = new ResizeObserver(() => {
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(container.clientWidth, container.clientHeight);
  });
  observer.observe(container);

  function animate() {
    requestAnimationFrame(animate);
    if (!isScrolling && pivot) {
      // pivot.rotation.y += 0.003;
    }
    renderer.render(scene, camera);
  }
  animate();
</script>

<style>
  /* Tall region that creates scroll room; canvas stays sticky inside */
  .hero-scroll-region {
    height: 200vh;
    position: relative;
  }

  .hero-monitor {
    height: 100vh;
    position: sticky;
    top: 0;
    width: 100%;
  }

  #hero-canvas {
    display: block;
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }
</style>
